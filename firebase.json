{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase.*.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "docs/**",
      "uploads/**",
      "scripts/**",
      "HANDOFF.md",
      "README.md"
    ],
    "headers": [
      {
        "source": "src/**/*.@(js|jsx)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
      },
      {
        "source": "src/**/*.css",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
      },
      {
        "source": "**/*.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
